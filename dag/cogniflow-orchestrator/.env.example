# ── Cogniflow Orchestrator — Environment Variables ───────────────────────────
#
# Copy this file to .env and adjust values, or export variables directly.
# None of these are required — all have sensible defaults.

# ── Claude CLI location ───────────────────────────────────────────────────────
# The orchestrator auto-detects the claude binary.
# Set this only if auto-detection fails (e.g. custom install path).
#
# Windows (Claude Desktop subscription install):
#   CLAUDE_BIN=C:\Users\<you>\AppData\Local\Programs\claude\claude.exe
#
# Windows (npm global install):
#   CLAUDE_BIN=C:\Users\<you>\AppData\Roaming\npm\claude.cmd
#
# macOS/Linux:
#   CLAUDE_BIN=/usr/local/bin/claude
#
# CLAUDE_BIN=

# ── Per-agent timeout (seconds) ───────────────────────────────────────────────
# Kill a claude call if it runs longer than this.
# Increase for large research tasks (complex prompts may take 2–5 min).
AGENT_TIMEOUT=300

# ── Token budget (IMP-06) ─────────────────────────────────────────────────────
# Approximate context window of the claude model you are using.
# Claude 3.5 Sonnet / Haiku: 200 000 tokens
# Claude 3 Opus:              200 000 tokens
MODEL_CONTEXT_LIMIT=180000

# Fraction of context_limit reserved for input.
# The remaining fraction is left for the model's output.
INPUT_BUDGET_FRACTION=0.66

# ── Output versioning ─────────────────────────────────────────────────────────
# Set to 0 to disable versioned output files (only keep 05_output.md).
KEEP_OUTPUT_VERSIONS=1

# ── Parallelism ───────────────────────────────────────────────────────────────
# Maximum number of agent threads running simultaneously in a parallel layer.
MAX_PARALLEL_AGENTS=8

# ── Verbosity ─────────────────────────────────────────────────────────────────
# Set to 0 to suppress per-agent progress lines (useful in CI).
VERBOSE=1
